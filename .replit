modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]

[userenv.development]
YT_DLP_PATH = "/home/runner/workspace/backend/scripts/yt-dlp-shim.sh"

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 25301
externalPort = 80
