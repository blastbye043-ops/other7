# Required
DATABASE_URL=postgres://user:password@host:5432/dbname

# Comma-separated list of allowed frontend origins (e.g. your Vercel domain).
# Omit to allow all origins.
CORS_ORIGINS=https://your-app.vercel.app

# Optional — override binary locations. Not needed on Render (the Docker
# image already sets these); useful for other hosts or local overrides.
# YT_DLP_PATH=/usr/local/bin/yt-dlp
# FFMPEG_PATH=/usr/bin/ffmpeg
# DOWNLOADS_DIR=/tmp/ytdown-downloads

LOG_LEVEL=info
