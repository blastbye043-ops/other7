# Base URL of the deployed API server, e.g. https://your-api.onrender.com
# Leave unset for same-origin /api/* calls (local dev or single-host deployment).
VITE_API_URL=

# Public URL of the frontend site, e.g. https://ytoudown.com
# Used for canonical URLs, Open Graph tags, and JSON-LD structured data.
# Defaults to https://ytoudown.com when unset.
VITE_SITE_URL=
