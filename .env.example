# ─── Database ────────────────────────────────────────────────────────────────
# Required by the API server and DB migrations.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:password@localhost:5432/ytoudown

# ─── API Server ──────────────────────────────────────────────────────────────
# Port the backend listens on (default: 8080)
PORT=8080

# Allowed CORS origins (comma-separated).
#   - Unset in local dev → all origins allowed (open for convenience)
#   - Unset in production → all cross-origin browser requests are rejected
#   Set to your frontend domain in production: https://ytoudown.com
CORS_ORIGINS=

# Log level: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info

# ─── Binary paths ────────────────────────────────────────────────────────────
# Override if yt-dlp / ffmpeg are not on your PATH.
# YT_DLP_PATH=/usr/local/bin/yt-dlp
# FFMPEG_PATH=/usr/bin/ffmpeg

# Where downloads are temporarily stored (default: backend/downloads/)
# DOWNLOADS_DIR=/tmp/ytoudown-downloads

# ─── Frontend dev server ─────────────────────────────────────────────────────
# Port the Vite dev server listens on (default: 3000).
# Read as PORT by vite.config.ts — same var name as the backend, so run
# the two servers in separate terminals with different values if needed.
# FRONTEND_PORT=3000   ← set PORT=3000 in the frontend terminal instead

# Port of the local API server, used by Vite's /api/* dev proxy.
# Only needed if you run the backend on something other than 8080.
# BACKEND_PORT=8080

# Sub-path prefix for the frontend (default: "/").
# Only needed when deploying behind a path prefix (e.g. BASE_PATH=/app).
# BASE_PATH=/

# ─── Public URLs (production only) ───────────────────────────────────────────
# Public URL of the deployed frontend — used for canonical URLs and SEO.
# Defaults to https://ytoudown.com when unset.
# VITE_SITE_URL=https://ytoudown.com

# Public URL of the API server, injected into the frontend at build time.
# Leave unset in local dev — the Vite proxy handles /api/* automatically.
# VITE_API_URL=https://ytoudown-api.onrender.com
