# ─── Database ────────────────────────────────────────────────────────────────
# Required for download history and analytics. Omit to disable those features.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:password@localhost:5432/ytdown

# ─── API Server ──────────────────────────────────────────────────────────────
# Port the backend listens on (default: 8080)
PORT=8080

# Allowed CORS origins (comma-separated).
#   - Unset in local dev → all origins allowed (open for convenience)
#   - Unset in production → all cross-origin requests are rejected
#   Set to your Vercel domain in production:
# CORS_ORIGINS=https://your-app.vercel.app

# Log level: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info

# ─── Binary paths ────────────────────────────────────────────────────────────
# Override if yt-dlp / ffmpeg are not on your PATH.
# YT_DLP_PATH=/usr/local/bin/yt-dlp
# FFMPEG_PATH=/usr/bin/ffmpeg

# Where downloads are temporarily stored (default: OS temp dir)
# DOWNLOADS_DIR=/tmp/ytdown-downloads

# ─── Frontend dev server ─────────────────────────────────────────────────────
# Port the Vite dev server listens on (default: 3000).
# Run frontend and backend in separate terminals with different PORT values.
# PORT=3000   ← set this in the frontend terminal

# Port of the local API server — used by Vite's /api/* dev proxy.
# Only needed if you run the backend on a port other than 8080.
# BACKEND_PORT=8080

# Sub-path prefix for the frontend (default: "/").
# Only needed when deploying behind a path prefix (e.g. BASE_PATH=/app).
# BASE_PATH=/

# ─── Public URLs (production only) ───────────────────────────────────────────
# Public URL of the deployed frontend — used for canonical URLs and SEO.
# VITE_SITE_URL=https://your-app.vercel.app

# Public URL of the API server, injected into the frontend at build time.
# Leave unset in local dev — the Vite proxy handles /api/* automatically.
# VITE_API_URL=https://ytoudown-api.onrender.com
